# Copie este arquivo para .env e ajuste para seu ambiente local.
# Nunca publique o .env real.

BASE_PROCESSAMENTO=./examples
PASTA_IMPORTACAO_GERAL=./examples/importacao_geral
MODELO_PLANILHA=./modelo_importacao.xlsx
HORARIO_ENCERRAMENTO=19

# Integração externa opcional
API_ENABLED=false
API_DRY_RUN=true
API_BASE_URL=https://api.exemplo.com
API_TOKEN=coloque_seu_token_apenas_no_env_local
API_TIMEOUT=60

TENTATIVAS_ABRIR_TXT=5
ESPERA_ABRIR_TXT_SEGUNDOS=5
